{
  "name": "pyhsm-ts",
  "version": "1.0.0",
  "description": "Production-hardened software HSM for Node.js",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "eslint": "eslint .",
    "format": "prettier --write \"*.ts\"",
    "format:check": "prettier --check \"*.ts\"",
    "ci": "npm run lint && npm run eslint && npm run format:check && npm test && npm run build"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "license": "MIT",
  "dependencies": {
    "@noble/ciphers": "1.2.1",
    "argon2": "0.41.1"
  },
  "devDependencies": {
    "@types/node": "22.15.17",
    "eslint": "9.27.0",
    "prettier": "3.5.3",
    "typescript": "5.8.3",
    "typescript-eslint": "8.32.1",
    "vitest": "3.1.3"
  }
}
